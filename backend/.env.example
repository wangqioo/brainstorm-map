# ─── vLLM on SPARK1 ────────────────────────────────────────────────────────────
# IP or hostname of your SPARK1 machine running vLLM
VLLM_BASE_URL=http://192.168.1.101:8000
# Model name exactly as registered in vLLM
VLLM_MODEL=Qwen/Qwen3.5-7B-Instruct
# API key (vLLM default is "EMPTY", change if you set --api-key)
VLLM_API_KEY=EMPTY

# ─── FunASR on SPARK2 (same machine, or localhost) ─────────────────────────────
FUNASR_HOST=localhost
FUNASR_PORT=10095
# ASR mode: offline | online | 2pass (2pass recommended for real-time)
FUNASR_MODE=2pass
